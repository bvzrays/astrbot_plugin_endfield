{
  "api_key": {
    "description": "API Key",
    "type": "string",
    "hint": "请前往 https://end.shallow.ink 获取秘钥",
    "obvious_hint": true,
    "default": ""
  },
  "auth_client_name": {
    "description": "授权客户端名称",
    "type": "string",
    "default": "终末地机器人"
  },
  "operator_list_bg": {
    "description": "干员列表背景图",
    "type": "string",
    "enum": [
      "random",
      "bg1.png",
      "bg2.png"
    ],
    "default": "random"
  },
  "render_timeout": {
    "description": "图片渲染超时时间(ms)",
    "type": "int",
    "default": 30000
  },
  "announcement_poll_interval": {
    "description": "公告订阅推送轮询间隔（分钟）",
    "type": "int",
    "default": 10
  },
  "auto_sign_in": {
    "description": "是否开启每日自动签到（每天自动执行）",
    "type": "bool",
    "default": true
  },
  "auto_sign_in_time": {
    "description": "自动签到执行时间 (格式 HH:MM)",
    "type": "string",
    "default": "00:05"
  }
}